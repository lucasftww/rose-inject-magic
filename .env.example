# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# Production builds: VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY must be set at build time
# (the app throws on load if they are missing when import.meta.env.PROD is true).
VITE_SUPABASE_PROJECT_ID="your_project_id_here"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key_here"
VITE_SUPABASE_URL="https://your_project_id_here.supabase.co"

# Meta Pixel (browser + alinhado ao snippet em index.html; Vite substitui %VITE_META_PIXEL_ID% no build)
VITE_META_PIXEL_ID="706054019233816"

# Supabase Edge Functions (secrets ou system_credentials — not Vite):
# META_ACCESS_TOKEN — obrigatório para CAPI (server-relay + pix-payment); sem isto o servidor não envia eventos à Meta
# META_PIXEL_ID — opcional se já estiver na tabela system_credentials
# META_TEST_EVENT_CODE — opcional; Events Manager → Testar eventos; remover em produção estável
