# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# Production builds: VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY must be set at build time
# (the app throws on load if they are missing when import.meta.env.PROD is true).
VITE_SUPABASE_PROJECT_ID="your_project_id_here"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key_here"
VITE_SUPABASE_URL="https://your_project_id_here.supabase.co"

# Supabase Edge Functions (secrets / dashboard — not Vite):
# META_ACCESS_TOKEN — CAPI
# META_PIXEL_ID — optional if not only in DB
# META_TEST_EVENT_CODE — optional; Events Manager → Testar eventos → remove when going live
